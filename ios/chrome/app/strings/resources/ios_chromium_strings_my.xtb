<translation id="5945387852661427312">သင်သည် <ph name="DOMAIN" /> က စီမံခန့်ခွဲထားသည့် အကောင့်ဖြင့် လက်မှတ်ထိုးဝင်နေပြီး သင့် Mises ဒေတာကို ထိန်းချုပ်ခွင့်ပေးထားပါသည်။ သင့်ဒေတာများသည် ဤအကောင့်နှင့် အပြီးအပိုင် ချိတ်ဆက်ထားပါမည်။ Mises မှ ထွက်လိုက်ခြင်းဖြင့် ဤစက်ပစ္စည်းပေါ်ရှိ ဒေတာများကို ဖျက်လိုက်မည် ဖြစ်သော်လည်း ၎င်းတို့သည် သင့် Google အကောင့်တွင် ကျန်ရှိနေဦးမည် ဖြစ်သည်။</translation>
<translation id="602807004951640891">Mises အသုံးပြုခြင်းဖြင့် သင်သည် <ph name="BEGIN_LINK_TOS" />ဝန်ဆောင်မှု စည်းကမ်းများ<ph name="END_LINK_TOS" /> ကို သဘောတူရာ ရောက်ပါသည်။</translation>
<translation id="6119647025869519954">Mises ကို မူရင်းသတ်မှတ်ရန်-
၁။ 'ဆက်တင်များ' ဖွင့်ပါ
၂။ 'မူရင်း ဘရောင်ဇာအက်ပ်' ကို တို့ပါ
၃။ Mises ကို ရွေးပါ။</translation>
<translation id="6155422572367400359">ဤဝဘ်ဆိုက်၊ သင်၏ Google Account နှင့် Mises သို့ လက်မှတ်ထိုးဝင်ပါ။ စင့်ခ်လုပ်ခြင်းကို နောင်တွင် ဖွင့်နိုင်သည်။</translation>
<translation id="6183442264225539303">ဤဝဘ်ဆိုက်နှင့် Mises သို့ လက်မှတ်ထိုးဝင်ပါ။ စင့်ခ်လုပ်ခြင်းကို နောင်တွင် ဖွင့်နိုင်သည်။</translation>
<translation id="6268381023930128611">Mises မှထွက်မလား။</translation>
<translation id="632825460376924298">Mises သို့ လက်မှတ်ထိုးဝင်ခွင့်ပြုရန်</translation>
<translation id="6337530241089703714">ဤစက်မှ သင်၏ Mises ဒေတာများကို ရှင်းထုတ်မည် (သို့) ဆက်ထားရှိမည်ကို ရွေးပါ</translation>
<translation id="6424492062988593837">Mises သည် ပိုလို့ကို ကောင်းလာပါပြီ! ဗားရှင်း အသစ် ရနိုင်ပြီ။</translation>
<translation id="6752854822223394465">သင့်အဖွဲ့အစည်းသည် Mises ကို စနစ်ထည့်သွင်းနေသည်...</translation>
<translation id="6820823224820483452">Mises က စကားဝှက်အားလုံးကို စစ်ဆေး၍မရပါ။ မနက်ဖြန် ထပ်စမ်းကြည့်ပါ။</translation>
<translation id="7018284295775193585">Mises က အပ်ဒိတ်မလုပ်နိုင်ပါ</translation>
<translation id="7045244423563602563">Mises ကို သင့်စိတ်ကြိုက်ပြင်ဆင်လိုက်ပါ</translation>
<translation id="7099326575020694068">မျက်နှာပြင်ခွဲခြမ်းပြသသည့်မုဒ်တွင် Mises သည် သင့်ကင်မရာကို အသုံးပြု၍ မရပါ</translation>
<translation id="7108914401277488191">Mises ဖြင့် အလုပ်ပိုပြီးအောင် လုပ်လိုက်ပါ</translation>
<translation id="7118091470949186573">ယခုအချိန်တွင် မက်ဆေ့ဂျ်များ၊ စာရွက်စာတမ်းများနှင့် အခြားအက်ပ်များတွင် အချိန်မရွေး လင့်ခ်များကို တို့ပြီး Mises ကို အသုံးပြုနိုင်သည်။</translation>
<translation id="7208566199746267865">Mises သည် သင့်အကောင့်များကို ဝဘ်သို့ပို့ဆောင်ပေးခြင်းဖြင့် သင့်အချိန်ကို ချွေတာပေးပါသည်။ ဆက်တင်များထဲတွင် အကောင့်များကို ပေါင်းထည့်ခြင်း သို့မဟုတ် ဖယ်ရှားခြင်းတို့ ပြုလုပ်နိုင်သည်။</translation>
<translation id="725427773388857052">ဒေတာပေါက်ကြားမှု၊ မလုံခြုံသော ဝဘ်ဆိုက်များနှင့် အခြားအန္တရာယ်များမှ သင့်ကိုကာကွယ်ရန် Mises က ကူညီပေးနိုင်သည်။</translation>
<translation id="7269362888766543920">အချို့ အပိုပရိုဂရမ်များသည် Mises ကို ရပ်တန့်စေပါသည်။ ၎င်းတို့ကို ဖယ်ရှားကြည့်ပါ။</translation>
<translation id="7313655110045230863">Mises ကို မူရင်းဘရောင်ဇာ သတ်မှတ်ရန် ‘ဆက်တင်များ’ ဖွင့်ပါ။ ‘မူရင်း ဘရောင်ဇာအက်ပ်’ ကိုတို့ပြီး Mises ကိုရွေးပါ။</translation>
<translation id="7337881442233988129">Mises</translation>
<translation id="7357211569052832586">ရွေးချယ်ထားသည့် ဒေတာများကို Mises နှင့် စင့်ခ်လုပ်ထားသည့် စက်ပစ္စည်းများမှ ဖယ်ရှားလိုက်ပါပြီ။ history.google.com ၌ သင့် Google အကောင့်ထဲတွင် အခြား Google ဝန်ဆောင်မှုများမှ ရှာဖွေမှုများနှင့် လုပ်ဆောင်ချက်များကဲ့သို့ အခြားအင်တာနက် အသုံးပြုမှုမှတ်တမ်း ပုံစံများ ရှိနိုင်ပါသည်။</translation>
<translation id="7400689562045506105">Mises ကို နေရာတိုင်းတွင် အသုံးပြုပါ</translation>
<translation id="766897673682622022">ဒေတာပေါက်ကြားမှုတစ်ခုတွင် သင့်စကားဝှက် ဖော်ထုတ်ခံခဲ့ရသည်။ စကားဝှက်ကို ယခုပင်ပြောင်းလဲရန် Mises က အကြံပြုပါသည်။</translation>
<translation id="7674213385180944843">ကင်မရာကို ဖွင့်ရန် ဆက်တင်များ &gt; ပုဂ္ဂိုလ်ရေးဆိုင်ရာ &gt; ကင်မရာ &gt; Mises သို့သွားပါ။</translation>
<translation id="7746854981345936341">Mises အကြံပြုချက်။ 'နောက်သို့'၊ 'ရှေ့သို့' နှင့် 'ရှာဖွေရန်' ကဲ့သို့သော အချို့ခလုတ်များသည် ယခုအခါ မျက်နှာပြင်၏ အောက်ခြေတွင် ရှိပါသည်။</translation>
<translation id="7763454117143368771">အန္တရာယ်ဝဘ်ဆိုက်များရန်မှ အကာအကွယ်ရရှိရန်နှင့် သင်၏စကားဝှက်များ လုံခြုံစေရန် သင့်မူရင်းဘရောင်ဇာအဖြစ် Mises ကို သုံးနိုင်သည်</translation>
<translation id="786327964234957808">သင်သည် စင့်ခ်အကောင့်များကို <ph name="USER_EMAIL1" /> မှ <ph name="USER_EMAIL2" /> သို့ ပြောင်းနေပါသည်။ သင်၏လက်ရှိ Mises ဒေတာကို <ph name="DOMAIN" /> က စီမံခန့်ခွဲထားခြင်း ဖြစ်သည်။ ဤသို့ ပြုလုပ်ခြင်းအားဖြင့် ဤစက်ပစ္စည်းရှိ သင့်ဒေတာများကို ဖျက်လိုက်မည်ဖြစ်သော်လည်း ၎င်းဒေတာများသည် <ph name="USER_EMAIL1" /> တွင် ရှိနေဦးမည် ဖြစ်သည်။</translation>
<translation id="7890287942691234100">Mises ရှာဖွေစနစ် စတင်အသုံးပြုခြင်း</translation>
<translation id="7928628054454574139">အခြားအက်ပ်များတွင် လင့်ခ်များကိုတို့ပြီး Mises ကို အချိန်မရွေး ဖွင့်နိုင်သည်</translation>
<translation id="7931842119211730154">Mises ကို ပိတ်သည့်အခါ ရုပ်ဖျက်တဘ်များကို လော့ခ်ချရန်</translation>
<translation id="7980860476903281594">Mises သည် သင်၏တည်နေရာကို သင်ခွင့်ပြုသော ဝဘ်ဆိုက်များအား မျှဝေသည်။</translation>
<translation id="8013573822802650211">Mises အသုံးပြုသည့် နေရာမှန်သမျှမှ သင့်တဘ်များကိုကြည့်ရန် သင့်စက်အားလုံးတွင် လက်မှတ်ထိုးဝင်ပါ</translation>
<translation id="8073677936375100957">ဤစက်မှ သင်၏ Mises ဒေတာများကို ဖယ်ရှားလိုပါသလား။</translation>
<translation id="8175055321229419309">အကြံပြုချက်− <ph name="BEGIN_LINK" />Mises ကို အမြန်သုံးလင့်ခ်ဘားတန်းသို့ ရွှေ့ထားပါ<ph name="END_LINK" /></translation>
<translation id="8240981428553046115">Mises က အပ်ဒိတ်များကို စစ်ဆေး၍မရခဲ့ပါ။ နောက်မှ ထပ်စမ်းပါ။</translation>
<translation id="8586442755830160949">မူပိုင်ခွင့် <ph name="YEAR" /> The Mises ပြုစုသူများ။ မူပိုင်ခွင့်များ အားလုံးကို ချုပ်ထိန်းထားသည်။</translation>
<translation id="8663480472502753423">Mises ကို အပ်ဒိတ်ဖြစ်နေစေသည်</translation>
<translation id="8776843108004031667">ဤအကောင့်နှင့် သိမ်းမထားသော ဒေတာမှန်သမျှကို Mises မှ ဖယ်ရှားပါမည်။</translation>
<translation id="894437814105052438">သင်အကောင့်မှထွက်သောအခါ Mises သည် သင့် Google Account သို့ ဒေတာအသစ်များကို စင့်ခ်လုပ်မည်မဟုတ်ပါ။ ယခင်က စင့်ခ်လုပ်ထားသောဒေတာများ အကောင့်တွင် ဆက်ရှိနေပါမည်။</translation>
